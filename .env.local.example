# Toshi AI Terminal — OpenRouter API Key
# Obtain your key at: https://openrouter.ai/keys
# IMPORTANT: Configure HTTP referrer restriction in OpenRouter dashboard to
# allow only: https://gtoshinakano.github.io/fullstack-profile/*
# Without this key, the ToshiAITerminal component will not render.
NEXT_PUBLIC_OPENROUTER_API_KEY=your-openrouter-api-key-here
NEXT_PUBLIC_OPENROUTER_MODEL=openrouter/free
